      "mode": "managed",
      "type": "kubernetes_config_map",
      "name": "platform_api_dashboard",
      "provider": "provider[\"registry.terraform.io/hashicorp/kubernetes\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "binary_data": {},
            "data": {
              "platform-api.json": "{\n  \"title\": \"Platform API — RED + Runtime\",\n  \"uid\": \"platform-api-red\",\n  \"tags\": [\"platform-api\", \"red-method\", \"portfolio\"],\n  \"timezone\": \"browser\",\n  \"schemaVersion\": 39,\n  \"version\": 1,\n  \"refresh\": \"10s\",\n  \"time\": { \"from\": \"now-15m\", \"to\": \"now\" },\n  \"templating\": {\n    \"list\": [\n      {\n        \"name\": \"job\",\n        \"type\": \"query\",\n        \"datasource\": { \"type\": \"prometheus\", \"uid\": \"prometheus\" },\n        \"query\": \"label_values(http_requests_total, job)\",\n        \"current\": { \"text\": \"platform-api\", \"value\": \"platform-api\" },\n        \"refresh\": 2\n      }\n    ]\n  },\n  \"panels\": [\n    {\n      \"id\": 1,\n      \"type\": \"stat\",\n      \"title\": \"Request Rate (req/s)\",\n      \"gridPos\": { \"h\": 6, \"w\": 6, \"x\": 0, \"y\": 0 },\n      \"targets\": [\n        {\n          \"expr\": \"sum(rate(http_requests_total{job=\\\"$job\\\"}[1m]))\",\n          \"legendFormat\": \"rps\",\n          \"refId\": \"A\"\n        }\n      ],\n      \"fieldConfig\": {\n        \"defaults\": {\n          \"unit\": \"reqps\",\n          \"decimals\": 2,\n          \"color\": { \"mode\": \"thresholds\" },\n          \"thresholds\": {\n            \"mode\": \"absolute\",\n            \"steps\": [\n              { \"color\": \"green\", \"value\": null },\n              { \"color\": \"yellow\", \"value\": 50 },\n              { \"color\": \"red\", \"value\": 200 }\n            ]\n          }\n        }\n      },\n      \"options\": { \"colorMode\": \"background\", \"graphMode\": \"area\", \"textMode\": \"auto\" }\n    },\n    {\n      \"id\": 2,\n      \"type\": \"stat\",\n      \"title\": \"Error Rate (5xx %)\",\n      \"gridPos\": { \"h\": 6, \"w\": 6, \"x\": 6, \"y\": 0 },\n      \"targets\": [\n        {\n          \"expr\": \"100 * sum(rate(http_requests_total{job=\\\"$job\\\",status=~\\\"5..\\\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\\\"$job\\\"}[5m])), 0.001)\",\n          \"legendFormat\": \"err %\",\n          \"refId\": \"A\"\n        }\n      ],\n      \"fieldConfig\": {\n        \"defaults\": {\n          \"unit\": \"percent\",\n          \"decimals\": 2,\n          \"color\": { \"mode\": \"thresholds\" },\n          \"thresholds\": {\n            \"mode\": \"absolute\",\n            \"steps\": [\n              { \"color\": \"green\", \"value\": null },\n              { \"color\": \"yellow\", \"value\": 1 },\n              { \"color\": \"red\", \"value\": 5 }\n            ]\n          }\n        }\n      },\n      \"options\": { \"colorMode\": \"background\", \"graphMode\": \"area\" }\n    },\n    {\n      \"id\": 3,\n      \"type\": \"stat\",\n      \"title\": \"p95 Latency\",\n      \"gridPos\": { \"h\": 6, \"w\": 6, \"x\": 12, \"y\": 0 },\n      \"targets\": [\n        {\n          \"expr\": \"histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\\\"$job\\\"}[5m])))\",\n          \"legendFormat\": \"p95\",\n          \"refId\": \"A\"\n        }\n      ],\n      \"fieldConfig\": {\n        \"defaults\": {\n          \"unit\": \"s\",\n          \"decimals\": 3,\n          \"color\": { \"mode\": \"thresholds\" },\n          \"thresholds\": {\n            \"mode\": \"absolute\",\n            \"steps\": [\n              { \"color\": \"green\", \"value\": null },\n              { \"color\": \"yellow\", \"value\": 0.1 },\n              { \"color\": \"red\", \"value\": 0.5 }\n            ]\n          }\n        }\n      },\n      \"options\": { \"colorMode\": \"background\", \"graphMode\": \"area\" }\n    },\n    {\n      \"id\": 4,\n      \"type\": \"stat\",\n      \"title\": \"In-Flight Requests\",\n      \"gridPos\": { \"h\": 6, \"w\": 6, \"x\": 18, \"y\": 0 },\n      \"targets\": [\n        {\n          \"expr\": \"sum(http_inflight_requests{job=\\\"$job\\\"})\",\n          \"legendFormat\": \"in-flight\",\n          \"refId\": \"A\"\n        }\n      ],\n      \"fieldConfig\": {\n        \"defaults\": {\n          \"unit\": \"short\",\n          \"decimals\": 0,\n          \"color\": { \"mode\": \"thresholds\" },\n          \"thresholds\": {\n            \"mode\": \"absolute\",\n            \"steps\": [\n              { \"color\": \"green\", \"value\": null },\n              { \"color\": \"yellow\", \"value\": 10 },\n              { \"color\": \"red\", \"value\": 50 }\n            ]\n          }\n        }\n      },\n      \"options\": { \"colorMode\": \"background\", \"graphMode\": \"area\" }\n    },\n    {\n      \"id\": 5,\n      \"type\": \"timeseries\",\n      \"title\": \"Request Rate by Path \u0026 Status\",\n      \"gridPos\": { \"h\": 9, \"w\": 12, \"x\": 0, \"y\": 6 },\n      \"targets\": [\n        {\n          \"expr\": \"sum by (path, status) (rate(http_requests_total{job=\\\"$job\\\"}[1m]))\",\n          \"legendFormat\": \"{{path}} [{{status}}]\",\n          \"refId\": \"A\"\n        }\n      ],\n      \"fieldConfig\": {\n        \"defaults\": {\n          \"unit\": \"reqps\",\n          \"custom\": { \"drawStyle\": \"line\", \"lineInterpolation\": \"smooth\", \"fillOpacity\": 15, \"lineWidth\": 2 }\n        }\n      },\n      \"options\": { \"legend\": { \"displayMode\": \"table\", \"placement\": \"bottom\", \"calcs\": [\"mean\", \"max\"] } }\n    },\n    {\n      \"id\": 6,\n      \"type\": \"timeseries\",\n      \"title\": \"Latency p50 / p95 / p99\",\n      \"gridPos\": { \"h\": 9, \"w\": 12, \"x\": 12, \"y\": 6 },\n      \"targets\": [\n        {\n          \"expr\": \"histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\\\"$job\\\"}[5m])))\",\n          \"legendFormat\": \"p50\",\n          \"refId\": \"A\"\n        },\n        {\n          \"expr\": \"histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\\\"$job\\\"}[5m])))\",\n          \"legendFormat\": \"p95\",\n          \"refId\": \"B\"\n        },\n        {\n          \"expr\": \"histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\\\"$job\\\"}[5m])))\",\n          \"legendFormat\": \"p99\",\n          \"refId\": \"C\"\n        }\n      ],\n      \"fieldConfig\": {\n        \"defaults\": {\n          \"unit\": \"s\",\n          \"custom\": { \"drawStyle\": \"line\", \"lineInterpolation\": \"smooth\", \"fillOpacity\": 10, \"lineWidth\": 2 }\n        }\n      },\n      \"options\": { \"legend\": { \"displayMode\": \"table\", \"placement\": \"bottom\", \"calcs\": [\"mean\", \"max\"] } }\n    },\n    {\n      \"id\": 7,\n      \"type\": \"timeseries\",\n      \"title\": \"Latency Heatmap (request duration buckets)\",\n      \"gridPos\": { \"h\": 9, \"w\": 12, \"x\": 0, \"y\": 15 },\n      \"targets\": [\n        {\n          \"expr\": \"sum by (le) (rate(http_request_duration_seconds_bucket{job=\\\"$job\\\"}[1m]))\",\n          \"legendFormat\": \"{{le}}\",\n          \"refId\": \"A\"\n        }\n      ],\n      \"fieldConfig\": { \"defaults\": { \"unit\": \"s\" } }\n    },\n    {\n      \"id\": 8,\n      \"type\": \"timeseries\",\n      \"title\": \"Errors by Status Code\",\n      \"gridPos\": { \"h\": 9, \"w\": 12, \"x\": 12, \"y\": 15 },\n      \"targets\": [\n        {\n          \"expr\": \"sum by (status) (rate(http_requests_total{job=\\\"$job\\\",status=~\\\"[45]..\\\"}[1m]))\",\n          \"legendFormat\": \"{{status}}\",\n          \"refId\": \"A\"\n        }\n      ],\n      \"fieldConfig\": {\n        \"defaults\": {\n          \"unit\": \"reqps\",\n          \"custom\": { \"drawStyle\": \"bars\", \"fillOpacity\": 80, \"lineWidth\": 1 }\n        }\n      }\n    },\n    {\n      \"id\": 9,\n      \"type\": \"row\",\n      \"title\": \"Go Runtime\",\n      \"gridPos\": { \"h\": 1, \"w\": 24, \"x\": 0, \"y\": 24 },\n      \"collapsed\": false\n    },\n    {\n      \"id\": 10,\n      \"type\": \"timeseries\",\n      \"title\": \"Goroutines\",\n      \"gridPos\": { \"h\": 8, \"w\": 8, \"x\": 0, \"y\": 25 },\n      \"targets\": [\n        {\n          \"expr\": \"sum by (pod) (go_goroutines{job=\\\"$job\\\"})\",\n          \"legendFormat\": \"{{pod}}\",\n          \"refId\": \"A\"\n        }\n      ],\n      \"fieldConfig\": { \"defaults\": { \"unit\": \"short\" } }\n    },\n    {\n      \"id\": 11,\n      \"type\": \"timeseries\",\n      \"title\": \"Memory (heap in use)\",\n      \"gridPos\": { \"h\": 8, \"w\": 8, \"x\": 8, \"y\": 25 },\n      \"targets\": [\n        {\n          \"expr\": \"sum by (pod) (go_memstats_heap_inuse_bytes{job=\\\"$job\\\"})\",\n          \"legendFormat\": \"{{pod}}\",\n          \"refId\": \"A\"\n        }\n      ],\n      \"fieldConfig\": { \"defaults\": { \"unit\": \"bytes\" } }\n    },\n    {\n      \"id\": 12,\n      \"type\": \"timeseries\",\n      \"title\": \"GC Pause (p99)\",\n      \"gridPos\": { \"h\": 8, \"w\": 8, \"x\": 16, \"y\": 25 },\n      \"targets\": [\n        {\n          \"expr\": \"go_gc_duration_seconds{job=\\\"$job\\\",quantile=\\\"1\\\"}\",\n          \"legendFormat\": \"{{pod}} max\",\n          \"refId\": \"A\"\n        }\n      ],\n      \"fieldConfig\": { \"defaults\": { \"unit\": \"s\" } }\n    }\n  ]\n}\n"
            },
            "id": "observability/platform-api-dashboard",
