            "disable_webhooks": false,
            "force_update": false,
            "id": "argocd",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "v3.1.8",
                "chart": "argo-cd",
                "first_deployed": 1779424274,
                "last_deployed": 1779424274,
                "name": "argocd",
                "namespace": "argocd",
                "notes": "\nIn order to access the server UI you have the following options:\n\n1. kubectl port-forward service/argocd-server -n argocd 8080:443\n\n    and then open the browser on http://localhost:8080 and accept the certificate\n\n2. enable ingress in the values file `server.ingress.enabled` and either\n      - Add the annotation for ssl passthrough: https://argo-cd.readthedocs.io/en/stable/operator-manual/ingress/#option-1-ssl-passthrough\n      - Set the `configs.params.\"server.insecure\"` in the values file and terminate SSL at your ingress: https://argo-cd.readthedocs.io/en/stable/operator-manual/ingress/#option-2-multiple-ingress-objects-and-hosts\n\n\nAfter reaching the UI the first time you can login with username: admin and the random password generated during the installation. You can find the password by running:\n\nkubectl -n argocd get secret argocd-initial-admin-secret -o jsonpath=\"{.data.password}\" | base64 -d\n\n(You should delete the initial secret afterwards as suggested by the Getting Started Guide: https://argo-cd.readthedocs.io/en/stable/getting_started/#4-login-using-the-cli)\n",
                "revision": 1,
                "values": "{\"applicationSet\":{\"metrics\":{\"enabled\":true,\"serviceMonitor\":{\"additionalLabels\":{\"release\":\"kps\"},\"enabled\":true}},\"replicas\":1,\"resources\":{\"limits\":{\"memory\":\"256Mi\"},\"requests\":{\"cpu\":\"25m\",\"memory\":\"64Mi\"}}},\"configs\":{\"cm\":{\"application.instanceLabelKey\":\"argocd.argoproj.io/instance\",\"server.rbac.log.enforce.enable\":\"false\"},\"params\":{\"server.insecure\":true},\"rbac\":{\"policy.default\":\"role:readonly\"},\"secret\":{\"argocdServerAdminPassword\":\"$2a$10$rjFKQiJK.4y8eKYkJitA0.QhWCFO5Wlcchu3H7YPX.D8hzxvo95VC\",\"argocdServerAdminPasswordMtime\":\"2026-05-21T00:00:00Z\"}},\"controller\":{\"metrics\":{\"enabled\":true,\"serviceMonitor\":{\"additionalLabels\":{\"release\":\"kps\"},\"enabled\":true,\"namespace\":\"argocd\"}},\"replicas\":1,\"resources\":{\"limits\":{\"memory\":\"1Gi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}}},\"crds\":{\"install\":true,\"keep\":true},\"dex\":{\"enabled\":false},\"global\":{\"domain\":\"argocd.platform-lab.test\"},\"notifications\":{\"enabled\":false},\"redis\":{\"resources\":{\"limits\":{\"memory\":\"256Mi\"},\"requests\":{\"cpu\":\"25m\",\"memory\":\"64Mi\"}}},\"repoServer\":{\"metrics\":{\"enabled\":true,\"serviceMonitor\":{\"additionalLabels\":{\"release\":\"kps\"},\"enabled\":true}},\"replicas\":1,\"resources\":{\"limits\":{\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"50m\",\"memory\":\"128Mi\"}}},\"server\":{\"metrics\":{\"enabled\":true,\"serviceMonitor\":{\"additionalLabels\":{\"release\":\"kps\"},\"enabled\":true}},\"replicas\":1,\"resources\":{\"limits\":{\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"50m\",\"memory\":\"128Mi\"}}}}",
                "version": "8.6.3"
              }
            ],
            "name": "argocd",
            "namespace": "argocd",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://argoproj.github.io/argo-helm",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [
              {
                "name": "configs.secret.argocdServerAdminPassword",
                "type": "",
                "value": "$2a$10$rjFKQiJK.4y8eKYkJitA0.QhWCFO5Wlcchu3H7YPX.D8hzxvo95VC"
              },
              {
                "name": "configs.secret.argocdServerAdminPasswordMtime",
                "type": "",
                "value": "2026-05-21T00:00:00Z"
              }
            ],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 600,
            "upgrade_install": null,
            "values": [
              "global:\n  domain: argocd.platform-lab.test\n\nconfigs:\n  params:\n    server.insecure: true\n\n  cm:\n    application.instanceLabelKey: argocd.argoproj.io/instance\n    server.rbac.log.enforce.enable: \"false\"\n\n  rbac:\n    policy.default: role:readonly\n\ncontroller:\n  replicas: 1\n  resources:\n    requests:\n      cpu: 100m\n      memory: 256Mi\n    limits:\n      memory: 1Gi\n  metrics:\n    enabled: true\n    serviceMonitor:\n      enabled: true\n      namespace: argocd\n      additionalLabels:\n        release: kps\n\nserver:\n  replicas: 1\n  resources:\n    requests:\n      cpu: 50m\n      memory: 128Mi\n    limits:\n      memory: 512Mi\n  metrics:\n    enabled: true\n    serviceMonitor:\n      enabled: true\n      additionalLabels:\n        release: kps\n\nrepoServer:\n  replicas: 1\n  resources:\n    requests:\n      cpu: 50m\n      memory: 128Mi\n    limits:\n      memory: 512Mi\n  metrics:\n    enabled: true\n    serviceMonitor:\n      enabled: true\n      additionalLabels:\n        release: kps\n\napplicationSet:\n  replicas: 1\n  resources:\n    requests:\n      cpu: 25m\n      memory: 64Mi\n    limits:\n      memory: 256Mi\n  metrics:\n    enabled: true\n    serviceMonitor:\n      enabled: true\n      additionalLabels:\n        release: kps\n\nnotifications:\n  enabled: false\n\ndex:\n  enabled: false\n\nredis:\n  resources:\n    requests:\n      cpu: 25m\n      memory: 64Mi\n    limits:\n      memory: 256Mi\n\ncrds:\n  install: true\n  keep: true\n"
            ],
            "verify": false,
            "version": "8.6.3",
            "wait": true,
            "wait_for_jobs": true
          },
